<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JARVIS POCKET // WEB BRIDGE</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #0a0a0f;
    --panel: #131320;
    --line: #26263a;
    --violet: #8b5cf6;
    --violet-dim: #4c3480;
    --rose: #ff4d6d;
    --text: #e9e7f5;
    --text-dim: #8f8ba8;
    --ok: #4ade80;
  }
  *{ box-sizing: border-box; }
  html,body{ margin:0; padding:0; }
  body{
    background: radial-gradient(circle at 50% -10%, #1a1330 0%, #0a0a0f 55%);
    color: var(--text);
    font-family: 'Sora', sans-serif;
    min-height: 100vh;
    display:flex;
    justify-content:center;
    padding: 32px 16px 80px;
  }
  .wrap{ width:100%; max-width: 520px; }

  .eyebrow{
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  h1{
    font-size: 26px;
    margin: 0 0 28px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  h1 span{ color: var(--violet); }

  .eye-stage{
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 28px 20px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .eye-stage::before{
    content:"";
    position:absolute; inset:0;
    background: radial-gradient(circle at 50% 20%, rgba(139,92,246,0.16), transparent 60%);
    pointer-events:none;
  }
  canvas#eye{ display:block; margin: 0 auto; }
  .state-label{
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--violet);
    margin-top: 12px;
  }
  .state-sub{ font-size: 12px; color: var(--text-dim); margin-top: 4px; min-height: 16px; }

  .panel{
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 20px;
    margin-top: 16px;
  }
  .panel h2{
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 14px;
    font-weight: 400;
  }

  .conn-row{ display:flex; gap:8px; }
  input#ip{
    flex:1;
    background: #0f0f1a;
    border: 1px solid var(--line);
    color: var(--text);
    padding: 11px 12px;
    border-radius: 10px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    outline: none;
  }
  input#ip:focus{ border-color: var(--violet); }
  button{
    font-family: 'Sora', sans-serif;
    font-weight: 600;
    font-size: 13px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 0.08s ease, opacity 0.15s ease;
  }
  button:active{ transform: scale(0.97); }
  .btn-primary{
    background: var(--violet);
    color: #fff;
    padding: 11px 18px;
    white-space: nowrap;
  }
  .btn-primary:disabled{ opacity: 0.5; cursor: default; }

  .status-row{ display:flex; align-items:center; gap:8px; margin-top: 12px; font-size: 12.5px; color: var(--text-dim); }
  .dot{ width:8px; height:8px; border-radius:50%; background: #55506e; flex-shrink:0; }
  .dot.live{ background: var(--ok); box-shadow: 0 0 8px var(--ok); }
  .dot.err{ background: var(--rose); box-shadow: 0 0 8px var(--rose); }

  .voice-grid{ display:grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .voice-btn{
    background: #1a1a2b;
    border: 1px solid var(--line);
    color: var(--text);
    padding: 13px 10px;
    text-align: left;
    border-radius: 12px;
    font-size: 13px;
  }
  .voice-btn:hover{ border-color: var(--violet-dim); }
  .voice-btn small{ display:block; color: var(--text-dim); font-family: 'Space Mono', monospace; font-size: 10px; margin-top: 3px; }

  .log{
    font-family: 'Space Mono', monospace;
    font-size: 11.5px;
    line-height: 1.7;
    color: var(--text-dim);
    max-height: 160px;
    overflow-y: auto;
  }
  .log div span{ color: var(--violet); }
  .log::-webkit-scrollbar{ width: 4px; }
  .log::-webkit-scrollbar-thumb{ background: var(--line); border-radius: 4px; }

  .footnote{
    font-size: 11.5px;
    color: var(--text-dim);
    margin-top: 18px;
    line-height: 1.6;
    text-align: center;
  }
</style>
</head>
<body>
<div class="wrap">
  <div class="eyebrow">JARVIS POCKET</div>
  <h1>Web <span>Bridge</span></h1>

  <div class="eye-stage">
    <canvas id="eye" width="220" height="140"></canvas>
    <div class="state-label" id="stateLabel">SLEEPING</div>
    <div class="state-sub" id="stateSub">waiting for connection</div>
  </div>

  <div class="panel">
    <h2>Device Connection</h2>
    <div class="conn-row">
      <input id="ip" type="text" placeholder="NodeMCU IP e.g. 192.168.1.42" />
      <button class="btn-primary" id="connectBtn">Connect</button>
    </div>
    <div class="status-row">
      <div class="dot" id="statusDot"></div>
      <span id="statusText">Not connected</span>
    </div>
  </div>

  <div class="panel">
    <h2>Voice Lines — Manual Test</h2>
    <div class="voice-grid">
      <button class="voice-btn" data-cmd="VOICE_HI">Wake greeting<small>hi.mp3</small></button>
      <button class="voice-btn" data-cmd="VOICE_MUSIC_PROMPT">Music prompt<small>want_music.mp3</small></button>
      <button class="voice-btn" data-cmd="VOICE_RETURN">Return to library<small>returning.mp3</small></button>
      <button class="voice-btn" data-cmd="VOICE_BYE">Goodbye<small>goodbye.mp3</small></button>
      <button class="voice-btn" data-cmd="VOICE_SLEEP">Sleep confirm<small>sleep_time.mp3</small></button>
    </div>
  </div>

  <div class="panel">
    <h2>Activity Log</h2>
    <div class="log" id="log"></div>
  </div>

  <div class="footnote">
    Runs entirely in this browser tab. Keep it open on the phone while<br>JARVIS Pocket is in use — commands are polled every second.
  </div>
</div>

<audio id="player" preload="auto"></audio>

<script>
  // ---------- Voice file map ----------
  const VOICE_FILES = {
    VOICE_HI: "JarvisVoice/hi.mp3",
    VOICE_MUSIC_PROMPT: "JarvisVoice/want_music.mp3",
    VOICE_RETURN: "JarvisVoice/returning.mp3",
    VOICE_BYE: "JarvisVoice/goodbye.mp3",
    VOICE_SLEEP: "JarvisVoice/sleep_time.mp3",
  };

  const player = document.getElementById("player");
  const logEl = document.getElementById("log");
  const stateLabel = document.getElementById("stateLabel");
  const stateSub = document.getElementById("stateSub");
  const statusDot = document.getElementById("statusDot");
  const statusText = document.getElementById("statusText");
  const ipInput = document.getElementById("ip");
  const connectBtn = document.getElementById("connectBtn");

  let deviceIp = localStorage.getItem("jarvis_ip") || "";
  ipInput.value = deviceIp;
  let pollTimer = null;

  function log(msg){
    const row = document.createElement("div");
    const time = new Date().toLocaleTimeString([], {hour12:false});
    row.innerHTML = `<span>${time}</span> ${msg}`;
    logEl.prepend(row);
    while(logEl.children.length > 40) logEl.removeChild(logEl.lastChild);
  }

  function setEyeState(label, sub, mode){
    stateLabel.textContent = label;
    stateSub.textContent = sub || "";
    drawEye(mode);
  }

  function playVoice(command){
    const file = VOICE_FILES[command];
    if(!file){ log(`Unknown command: ${command}`); return; }
    player.src = file;
    player.play().catch(err => log(`Playback blocked: ${err.message}`));
    log(`Playing → ${command}`);
    pulseTalk();
  }

  // wire up manual test buttons
  document.querySelectorAll(".voice-btn").forEach(btn => {
    btn.addEventListener("click", () => playVoice(btn.dataset.cmd));
  });

  // ---------- Connection / polling ----------
  connectBtn.addEventListener("click", () => {
    deviceIp = ipInput.value.trim();
    if(!deviceIp){ log("Enter a device IP first."); return; }
    localStorage.setItem("jarvis_ip", deviceIp);
    startPolling();
  });

  function startPolling(){
    if(pollTimer) clearInterval(pollTimer);
    statusText.textContent = "Connecting…";
    statusDot.className = "dot";
    pollTimer = setInterval(pollDevice, 1000);
    pollDevice();
  }

  async function pollDevice(){
    if(!deviceIp) return;
    try{
      const res = await fetch(`http://${deviceIp}/command`, { cache: "no-store" });
      if(!res.ok) throw new Error("bad response");
      const text = (await res.text()).trim();
      statusDot.className = "dot live";
      statusText.textContent = `Connected — ${deviceIp}`;
      if(text && text !== "NONE"){
        handleCommand(text);
      }
    }catch(err){
      statusDot.className = "dot err";
      statusText.textContent = "Can't reach device — check IP & Wi-Fi";
    }
  }

  function handleCommand(command){
    log(`Received ← ${command}`);
    if(command.startsWith("VOICE_")){
      playVoice(command);
    }
    // Reflect broader device states on the eye too
    switch(command){
      case "SLEEP": setEyeState("SLEEPING", "low power", "sleep"); break;
      case "WAKE": case "VOICE_HI": setEyeState("AWAKE", "hi, sir", "wake"); break;
      case "LIBRARY": setEyeState("LIBRARY", "browsing songs", "idle"); break;
      case "PLAY": setEyeState("PLAYING", "", "playing"); break;
      case "PAUSE": setEyeState("PAUSED", "", "idle"); break;
      case "VOICE_BYE": case "VOICE_SLEEP": setEyeState("SLEEPING", "goodbye, sir", "sleep"); break;
    }
  }

  // ---------- Eye canvas animation ----------
  const canvas = document.getElementById("eye");
  const ctx = canvas.getContext("2d");
  let talkPulse = 0;
  let blinkT = 0;

  function pulseTalk(){ talkPulse = 1; }

  function drawEye(mode){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    const cx = canvas.width/2, cy = canvas.height/2 + 6;
    let openAmt = 1;
    if(mode === "sleep") openAmt = 0.05;
    if(mode === "wake") openAmt = 0.6 + Math.sin(Date.now()/300)*0.1;

    const w = 150, h = 46 * openAmt;

    // glow
    ctx.save();
    ctx.shadowColor = "#8b5cf6";
    ctx.shadowBlur = 22;

    // eye shape (narrow almond, tilted)
    ctx.beginPath();
    ctx.ellipse(cx, cy, w/2, Math.max(h/2, 2), -0.05, 0, Math.PI*2);
    ctx.fillStyle = mode === "playing" ? "#a78bfa" : "#8b5cf6";
    ctx.fill();
    ctx.restore();

    // bottom lash line
    ctx.beginPath();
    ctx.moveTo(cx - w/2, cy + h/2);
    ctx.quadraticCurveTo(cx, cy + h/2 + 6, cx + w/2, cy + h/2 - 2);
    ctx.strokeStyle = "#e9e7f5";
    ctx.lineWidth = 2;
    ctx.stroke();

    // fringe line (diagonal sweep, emo signature)
    ctx.beginPath();
    ctx.moveTo(cx - w/2 - 6, cy - h/2 - 26);
    ctx.lineTo(cx - 6, cy - 2);
    ctx.strokeStyle = "#3a3550";
    ctx.lineWidth = 10;
    ctx.lineCap = "round";
    ctx.stroke();

    // tear-streak accent while "playing" / talking
    if(mode === "playing" || talkPulse > 0){
      ctx.beginPath();
      ctx.moveTo(cx + w/4, cy + h/2 + 4);
      ctx.lineTo(cx + w/4 - 3, cy + h/2 + 18 + talkPulse*4);
      ctx.strokeStyle = "#ff4d6d";
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    if(talkPulse > 0) talkPulse = Math.max(0, talkPulse - 0.04);
  }

  let currentMode = "sleep";
  function loop(){
    drawEye(currentMode);
    requestAnimationFrame(loop);
  }
  // keep drawEye aware of the last mode set by setEyeState
  const _origSetEyeState = setEyeState;
  setEyeState = function(label, sub, mode){
    currentMode = mode;
    _origSetEyeState(label, sub, mode);
  };

  drawEye("sleep");
  loop();

  if(deviceIp) startPolling();
  log("Web bridge ready.");
</script>
</body>
</html>
